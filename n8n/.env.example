# ===== Bot Telegram <-> Jenkins (rodando como workflow no n8n) =====
# Copie para .env, preencha e rode ./deploy.sh

# Token do bot (crie com o @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instâncias Jenkins que o bot controla — JSON em UMA linha.
# "url" é o endereço visto DE DENTRO do container n8n (mesma rede docker => http://<nome-do-container>:8080).
# Para adicionar outro Jenkins, acrescente outro objeto no array.
JENKINS_INSTANCES='[{"name":"principal","url":"http://jenkins:8080","user":"admin","token":"COLE_O_API_TOKEN_AQUI"}]'

# Ids de chat autorizados, separados por vírgula (pegue com /chatid). Vazio = aceita qualquer chat (INSEGURO).
ALLOWED_CHAT_IDS=

# Intervalo do polling em segundos (o bot responde em até ~POLL_SECONDS)
POLL_SECONDS=30

# Nome do container n8n nesta máquina
N8N_CONTAINER=n8n

# Id fixo do workflow no n8n (mantém o mesmo id entre deploys para atualizar em vez de duplicar)
WORKFLOW_ID=JenkinsTgBot0001
WORKFLOW_NAME="Jenkins Telegram Bot"
