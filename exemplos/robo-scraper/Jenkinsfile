// Pipeline deste robô (modo local). O job robo-scraper já roda isto,
// mas este arquivo fica aqui como referência.
pipeline {
    agent any
    options { timestamps() }
    stages {
        stage('Rodar robô') {
            steps {
                sh 'docker run --rm --volumes-from jenkins -w /robos/robo-scraper python:3.12-slim sh -c "pip install -q -r requirements.txt && python main.py"'
            }
        }
    }
}
