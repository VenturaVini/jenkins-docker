# Copie para .env e ajuste os valores:  cp .env.example .env

# Usuário e senha do admin do Jenkins (criados automaticamente no primeiro boot)
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=troque-esta-senha

# Portas expostas no host — usamos uma faixa "incomum" (38xx) de propósito,
# para não conflitar com serviços que usam as portas clássicas (8080, 8081...).
JENKINS_PORT=3878        # interface web
JENKINS_AGENT_PORT=3879  # agentes externos (JNLP) — raramente necessária

# URL pela qual o Jenkins será acessado (IP ou domínio do servidor)
JENKINS_URL=http://SEU_IP_OU_DOMINIO:3878/

# GID do grupo dono do socket do Docker no host.
# Descubra com:  stat -c %g /var/run/docker.sock
DOCKER_GID=988

# Pasta do host com os robôs/projetos locais (montada em /robos no Jenkins)
ROBOS_DIR=../robos
